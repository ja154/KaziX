# ============================================================================
# KaziX Backend Environment Variables (.env.example)
# ============================================================================
# Copy this file to .env and fill in the actual values for your environment.
# NEVER commit the actual .env file to version control!
#
# Required variables (must be set): Marked with ⚠️ REQUIRED
# Optional variables: Marked with ⊘ OPTIONAL or have defaults
#
# ============================================================================

# ── APPLICATION SETTINGS ─────────────────────────────────────────────────
# The environment where the app is running
# Options: "development" | "production" | "testing"
APP_ENV=development

# ⚠️ REQUIRED: Secret key for JWT token signing and session encryption
# Generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=your-super-secret-key-change-this-in-production

# The host the API server listens on (use 0.0.0.0 for Docker)
APP_HOST=0.0.0.0

# The port the API server listens on
APP_PORT=8000

# Comma-separated list of allowed CORS origins
# For Vercel frontend + custom domain:
# http://localhost:3000,http://localhost:5173,https://kazix.vercel.app,https://api.kazix.co.ke
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Comma-separated list of allowed Host headers for production
# Include your Render hostname until your custom API domain is live.
ALLOWED_HOSTS=localhost,127.0.0.1,*.onrender.com,api.kazix.co.ke

# Logging level: DEBUG | INFO (default) | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ⊘ OPTIONAL: Sentry DSN for error tracking in production
# Get this from https://sentry.io/ when ready for production monitoring
SENTRY_DSN=

# ============================================================================
# SUPABASE CONFIGURATION (Database & Authentication)
# ============================================================================

# ⚠️ REQUIRED: Your Supabase project URL
# Format: https://<project-id>.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# ⚠️ REQUIRED: Supabase anonymous key (public, safe for frontend)
# Get from: Supabase Dashboard → Project Settings → API Keys → anon key
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ REQUIRED: Supabase service role key (SECRET - backend only!)
# Get from: Supabase Dashboard → Project Settings → API Keys → service_role
# ⚠️ NEVER expose this key publicly or to the frontend!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ REQUIRED: Supabase JWT secret (used for token verification)
# Get from: Supabase Dashboard → Project Settings → API Keys → jwt_secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ============================================================================
# M-PESA PAYMENT PROCESSING (Safaricom)
# ============================================================================

# M-Pesa Daraja API environment: "sandbox" (testing) | "production" (live)
MPESA_ENV=sandbox

# ⚠️ REQUIRED: M-Pesa Daraja API consumer key (from Safaricom)
# Get from: https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=

# ⚠️ REQUIRED: M-Pesa Daraja API consumer secret (from Safaricom)
# Get from: https://developer.safaricom.co.ke/
MPESA_CONSUMER_SECRET=

# M-Pesa business short code
# Sandbox: 174379
# Production: Your actual shortcode from Safaricom
MPESA_SHORTCODE=174379

# ⚠️ REQUIRED: M-Pesa online (Lipa Na M-Pesa Online) passkey
# Get from Safaricom; different for sandbox vs production
MPESA_PASSKEY=

# Callback URL where M-Pesa sends payment confirmations
# Update for production deployment: https://api.kazix.co.ke/v1/mpesa/callback
MPESA_CALLBACK_URL=https://api.kazix.co.ke/v1/mpesa/callback

# ============================================================================
# AFRICA'S TALKING (SMS & OTP Services)
# ============================================================================

# Africa's Talking API environment: "sandbox" (testing) | "production" (live)
AT_ENV=sandbox

# ⚠️ REQUIRED: Africa's Talking API key
# Get from: https://africastalking.com/ → Sandbox / Live API
AT_API_KEY=

# Africa's Talking username (sandbox account: "sandbox")
AT_USERNAME=sandbox

# SMS sender ID (brand name visible in SMS)
AT_SENDER_ID=KaziX

# ============================================================================
# OTP RETRY CONFIGURATION
# ============================================================================

# Maximum number of OTP verification attempts before rate limiting
OTP_MAX_RETRIES=3

# Initial backoff time (in milliseconds) before retry
OTP_INITIAL_BACKOFF_MS=100

# Maximum backoff time (in milliseconds) between retries
OTP_MAX_BACKOFF_MS=5000

# Multiplier for exponential backoff (e.g., 100ms → 200ms → 400ms)
OTP_BACKOFF_MULTIPLIER=2.0

# Enable random jitter to prevent thundering herd
OTP_JITTER_ENABLED=true

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================

# Production checklist:
# 1. Change APP_ENV to "production"
# 2. Generate a new APP_SECRET_KEY (never use default)
# 3. Update ALLOWED_ORIGINS to your production domain only
# 4. Set SUPABASE_* keys from production Supabase project
# 5. Obtain M-Pesa production credentials from Safaricom
# 6. Obtain Africa's Talking production API key
# 7. Set SENTRY_DSN for production error tracking
# 8. Test health endpoint: GET /health
# 9. Run database migrations if not already applied

# For local development:
# - Use "development" environment
# - Use sandbox credentials for M-Pesa and Africa's Talking
# - ALLOWED_ORIGINS can include localhost URLs
# - .env file should NOT be in version control (.gitignore)

# For Docker/Render deployment:
# - Secrets should be set in the Render dashboard or via render.yaml prompt fields
# - Non-sensitive config can live in render.yaml envVars
# - The container honors PORT automatically on platforms like Render
# - Never pass .env file into container; use environment variables
