# ============================================================================
# KaziX Backend Production Environment Variables (.env.production.example)
# ============================================================================
# This is a TEMPLATE for production deployment on Render.
# Copy these values to your Render environment variables.
# See: Render Dashboard → Select KaziX service → Environment → Add Secret/Value
#
# Key differences from development:
# 1. APP_ENV=production (enables production logging & optimizations)
# 2. ALLOWED_ORIGINS includes production frontend URLs only
# 3. ALLOWED_HOSTS includes Render domain until custom domain is configured
# 4. All secrets must be strong and unique (not shared with development)
#
# ============================================================================

# ── APPLICATION SETTINGS ─────────────────────────────────────────────────
APP_ENV=production

# ⚠️ REQUIRED: Use a different, strong secret key for production
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=your-production-secret-key-here

APP_HOST=0.0.0.0
APP_PORT=8000

# ⚠️ CRITICAL: Add your frontend's production URL(s) here
# This fixes CORS preflight errors for fetch/POST requests
# Current: https://kazixfrontend.vercel.app (Vercel deployment)
# Future: https://kazix.vercel.app (after custom domain setup)
# Format: comma-separated, no spaces except after commas
ALLOWED_ORIGINS=https://kazixfrontend.vercel.app,https://kazix.vercel.app

# Allowed Host headers for production
# Keep *.onrender.com until custom domain (api.kazix.co.ke) is configured
ALLOWED_HOSTS=localhost,127.0.0.1,*.onrender.com,kazix-api.onrender.com,api.kazix.co.ke

# Enable production logging
LOG_LEVEL=INFO

# ⊘ OPTIONAL: Add Sentry DSN for production error tracking
SENTRY_DSN=https://your-sentry-project-url@sentry.io/your-project-id

# ============================================================================
# SUPABASE CONFIGURATION (Database & Authentication)
# ============================================================================
# Same as development, unless using separate production Supabase project
SUPABASE_URL=https://tziamornnxxsfofzyvpj.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=7dfe2d61-0151-4489-acd6-08ae1eeb3248

# ============================================================================
# M-PESA PAYMENT PROCESSING (Safaricom)
# ============================================================================
# Switch to production for live payments
MPESA_ENV=production
MPESA_CONSUMER_KEY=your-production-key
MPESA_CONSUMER_SECRET=your-production-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-production-passkey
MPESA_CALLBACK_URL=https://kazix-api.onrender.com/v1/mpesa/callback

# ============================================================================
# AFRICA'S TALKING SMS/VOICE PROVIDER
# ============================================================================
AT_API_KEY=your-production-api-key
AT_USERNAME=production-username
AT_SENDER_ID=KaziX
