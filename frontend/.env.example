# ============================================================================
# KaziX Frontend Environment Variables (.env.example)
# ============================================================================
# Copy this file to .env and fill in the actual values for your environment.
# NEVER commit the actual .env file to version control!
#
# Note: Frontend variables are injected at BUILD TIME (not runtime),
# so you must rebuild the deployment when changing these values.
#
# ============================================================================

# ── SUPABASE CONFIGURATION ───────────────────────────────────────────────

# ⚠️ REQUIRED: Your Supabase project URL
# Format: https://<project-id>.supabase.co
# Get from: Supabase Dashboard → Project Settings → API Keys
VITE_SUPABASE_URL=https://your-project.supabase.co

# ⚠️ REQUIRED: Supabase anonymous key (public, safe for browser)
# This key is publicly visible in browser network requests; use "anonymous" role only
# Get from: Supabase Dashboard → Project Settings → API Keys → anon key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── AUTHENTICATION CALLBACKS ─────────────────────────────────────────────

# Redirect URL after successful Supabase authentication
# Always point this at the auth callback page, not just the site origin.
# Local development: http://localhost:8000/pages/auth-callback.html
# Production via Vercel: https://kazix.vercel.app/pages/auth-callback.html
# Current Vercel project: https://kazixfrontend.vercel.app/pages/auth-callback.html
# For staging: https://staging.kazix.co.ke
SUPABASE_REDIRECT_URL=http://localhost:8000/pages/auth-callback.html

# ── OAUTH (OPTIONAL) ─────────────────────────────────────────────────────

# Google OAuth Client ID (public ID, safe to expose)
# Get from: Google Cloud Console → OAuth 2.0 → Client IDs
# https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ⊘ OPTIONAL: Backend API URL (if frontend needs explicit backend URL)
# Leave blank on Vercel/custom-domain deployments so /v1 and /health
# stay same-origin and use frontend rewrites instead of browser CORS.
# Local: http://localhost:8000
# Production fallback only: https://kazix-api.onrender.com or https://api.kazix.co.ke
VITE_API_URL=http://localhost:8000

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================

# Vercel Deployment:
# 1. Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in Vercel Project Settings
#    → Enter both in "Build and Deployment" → "Environment Variables"
# 2. Set SUPABASE_REDIRECT_URL to your Vercel callback URL
#    (e.g., https://kazixfrontend.vercel.app/pages/auth-callback.html)
# 3. Prefer leaving VITE_API_URL unset on Vercel so rewrites proxy /v1 and /health
#    without cross-origin browser requests. Only set it if you intentionally want
#    the browser to call the backend origin directly.
# 4. Rebuild/redeploy the Vercel project after changing these values
# 5. These values are embedded in the built HTML/JS at deploy time

# Custom Domain (Production):
# 1. Point your domain (e.g., kazix.co.ke) to Vercel nameservers or IP
# 2. Update SUPABASE_REDIRECT_URL to your custom domain
# 3. Rebuild on Vercel so the redirect URL reflects in the built app

# Local Development:
# 1. Copy this file to .env (don't commit it!)
# 2. Fill in VITE_SUPABASE_* with your development Supabase project
# 3. Set SUPABASE_REDIRECT_URL to http://localhost:8000/pages/auth-callback.html
# 4. Set VITE_API_URL to http://localhost:8000 when the API runs separately
# 5. Run `node generate-env.js` to create env.js from .env
# 6. Start dev server (e.g., python -m http.server or a local web server)

# Security Notes:
# - VITE_SUPABASE_ANON_KEY is public (visible in browser) → use "anonymous" role only
# - Never put backend service keys or production database credentials here
# - Google OAuth Client Secret should NOT be in frontend code (backend-side auth only)
# - Treat .env as local-only; never commit to version control
