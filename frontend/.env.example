# ============================================================================
# KaziX Frontend Environment Variables (.env.example)
# ============================================================================
# Copy this file to .env and fill in the actual values for your environment.
# NEVER commit the actual .env file to version control!
#
# Note: Frontend variables are injected at BUILD TIME (not runtime),
# so you must rebuild the deployment when changing these values.
#
# ============================================================================

# ── SUPABASE CONFIGURATION ───────────────────────────────────────────────

# ⚠️ REQUIRED: Your Supabase project URL
# Format: https://<project-id>.supabase.co
# Get from: Supabase Dashboard → Project Settings → API Keys
VITE_SUPABASE_URL=https://your-project.supabase.co

# ⚠️ REQUIRED: Supabase anonymous key (public, safe for browser)
# This key is publicly visible in browser network requests; use "anonymous" role only
# Get from: Supabase Dashboard → Project Settings → API Keys → anon key
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── AUTHENTICATION CALLBACKS ─────────────────────────────────────────────

# Redirect URL after successful Supabase authentication
# For local development: http://localhost:3000 or http://localhost:5173
# For production via Vercel: https://kazix.vercel.app or https://kazix.co.ke
# For staging: https://staging.kazix.co.ke
SUPABASE_REDIRECT_URL=http://localhost:3000

# ── OAUTH (OPTIONAL) ─────────────────────────────────────────────────────

# Google OAuth Client ID (public ID, safe to expose)
# Get from: Google Cloud Console → OAuth 2.0 → Client IDs
# https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ⊘ OPTIONAL: Backend API URL (if frontend needs explicit backend URL)
# Defaults to same domain; only set if backend is on different domain
# Local: http://localhost:8000
# Production: https://api.kazix.co.ke
VITE_API_URL=http://localhost:8000

# ============================================================================
# NOTES FOR DEPLOYMENT
# ============================================================================

# Vercel Deployment:
# 1. Set VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY in Vercel Project Settings
#    → Enter both in "Build and Deployment" → "Environment Variables"
# 2. Set SUPABASE_REDIRECT_URL to your Vercel domain (e.g., https://kazix.vercel.app)
# 3. Rebuild/redeploy the Vercel project after changing these values
# 4. These values are embedded in the built HTML/JS at deploy time

# Custom Domain (Production):
# 1. Point your domain (e.g., kazix.co.ke) to Vercel nameservers or IP
# 2. Update SUPABASE_REDIRECT_URL to your custom domain
# 3. Rebuild on Vercel so the redirect URL reflects in the built app

# Local Development:
# 1. Copy this file to .env (don't commit it!)
# 2. Fill in VITE_SUPABASE_* with your development Supabase project
# 3. Set SUPABASE_REDIRECT_URL to http://localhost:3000 or your dev URL
# 4. Run `node generate-env.js` to create env.js from .env
# 5. Start dev server (e.g., python -m http.server or a local web server)

# Security Notes:
# - VITE_SUPABASE_ANON_KEY is public (visible in browser) → use "anonymous" role only
# - Never put backend service keys or production database credentials here
# - Google OAuth Client Secret should NOT be in frontend code (backend-side auth only)
# - Treat .env as local-only; never commit to version control
